<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form" xmlns:core="sap.ui.core" xmlns:html="http://www.w3.org/1999/xhtml" xmlns:table="sap.ui.table" controllerName="kpmg.custom.testingTile.TestingTile.TestingTile.controller.CollaudoProgressHome" width="100%" height="100%">
		<Page id="mainCollaudoProgressPage" title="{i18n>CollaudoProgress.title}">
			<content>
				<!-- Header con filtri -->
				<Panel id="filterCollaudoProgressHomePanel" width="100%" height="100%" expandable="false" expanded="true" backgroundDesign="Transparent">
					<content>
						<VBox height="10%" renderType="Bare" class="sapUiSmallMargin">
							<!-- Filtri e Bottoni sulla stessa riga -->
							<HBox alignItems="End" justifyContent="SpaceBetween" width="100%">
								<!-- Filtri -->
								<VBox width="20%" height="100%" class="sapUiSmallMarginEnd">
									<Label text="{i18n>CollaudoProgress.filter.project}" />
									<ComboBox id="projectCollaudoProgressFilter" width="100%" placeholder="{i18n>CollaudoProgress.filter.project.placeholder}" items="{CollaudoProgressModel>/projects}">
										<core:ListItem key="{CollaudoProgressModel>}" text="{CollaudoProgressModel>}" />
									</ComboBox>
								</VBox>


								<VBox width="20%" height="100%" class="sapUiSmallMarginEnd">
									<Label text="{i18n>CollaudoProgress.filter.sfc}"/>
									<ComboBox id="sfcCollaudoProgressFilter" width="100%" placeholder="{i18n>CollaudoProgress.filter.sfc.placeholder}" items="{CollaudoProgressModel>/sfcs}" >
										<core:ListItem key="{CollaudoProgressModel>}" text="{CollaudoProgressModel>}" />
									</ComboBox>
								</VBox>


								<VBox width="20%" height="100%" class="sapUiSmallMarginEnd">
									<Label text="{i18n>CollaudoProgress.filter.co}"/>
									<ComboBox id="coCollaudoProgressFilter" width="100%" placeholder="{i18n>CollaudoProgress.filter.co.placeholder}" items="{CollaudoProgressModel>/cos}" >
										<core:ListItem key="{CollaudoProgressModel>}" text="{CollaudoProgressModel>}" />
									</ComboBox>
								</VBox>

                                <VBox width="20%" height="100%" class="sapUiSmallMarginEnd">
									<Label text="{i18n>CollaudoProgress.filter.customer}"/>
									<ComboBox id="customerCollaudoProgressFilter" width="100%" placeholder="{i18n>CollaudoProgress.filter.customer.placeholder}" items="{CollaudoProgressModel>/customers}" >
										<core:ListItem key="{CollaudoProgressModel>}" text="{CollaudoProgressModel>}" />
									</ComboBox>
								</VBox>
								
								<!-- Bottoni allineati verticalmente -->
								<VBox width="20%">
									<HBox width="100%" justifyContent="Center" class="sapUiTinyMarginBottom">
										<Button id="searchCollaudoProgressButton" text="{i18n>mainview.btn.search}" icon="sap-icon://search" press="onSearchPress" type="Emphasized" class="sapUiTinyMarginEnd searchBottom"/>
										<Button id="clearCollaudoProgressButton" text="{i18n>mainview.btn.clear}" icon="sap-icon://clear-filter" press="onClearPress" class="clearBottom" />
									</HBox>
                                    <HBox justifyContent="Center">
										<CheckBox id="sentToInstallationCollaudoProgress" select="loadData" text="Sent To Installation" />
										<CheckBox id="showAllCollaudoProgress" select="loadData" text="Show all" visible="false"/>
                                    </HBox>
								</VBox>
							</HBox>
						</VBox>
						<!-- Table -->
						<VBox height="85.5%" renderType="Bare">
							<table:Table
								id="CollaudoProgressTable"
								width="100%"
								busy="{CollaudoProgressModel>/BusyLoadingOpTable}" 
								rows="{CollaudoProgressModel>/tableData}"
								selectionMode="Single"
								ariaLabelledBy="title"
								rowSelectionChange="onRowSelectionChange"
								enableColumnReordering="true" 
								enableGrouping="true" 
								selectionBehavior="RowOnly"
								visibleRowCountMode="Auto"
								visibleRowCount="10" 
								rowHeight="45px"
								class="kpmgGDTable smallPaddingTable">
								<table:layoutData>
									<FlexItemData growFactor="1" baseSize="0%"/>
								</table:layoutData>
								<table:columns>
									<table:Column width="22%">
										<Label text="{i18n>CollaudoProgress.table.project}"/>
										<table:template>
											<Text text="{CollaudoProgressModel>project}" wrapping="false"/>
										</table:template>
									</table:Column>
									
									<table:Column width="20%">
										<Label text="{i18n>CollaudoProgress.table.sfc}"/>
										<table:template>
											<Text text="{CollaudoProgressModel>sfc}" wrapping="false"/>
										</table:template>
									</table:Column>
									
									<table:Column width="20%">
										<Label text="{i18n>CollaudoProgress.table.co}"/>
										<table:template>
											<Text text="{CollaudoProgressModel>co}" wrapping="false"/>
										</table:template>
									</table:Column>
									
									<table:Column width="20%">
										<Label text="{i18n>CollaudoProgress.table.customer}"/>
										<table:template>
											<Text text="{CollaudoProgressModel>customer}" wrapping="false"/>
										</table:template>
									</table:Column>
									

                                    <table:Column width="8%" hAlign="Center">
										<Label text="{i18n>CollaudoProgress.table.sentToInstallation}"/>
										<table:template >
											<CheckBox selected="{CollaudoProgressModel>sentToInstallation}" editable="false" />
										</table:template>
									</table:Column>

									<table:Column width="10%" hAlign="Center">
										<Label text="{i18n>CollaudoProgress.table.SFCstatus}"/>
										<table:template>
											<core:Icon src="{path: 'CollaudoProgressModel>sfcStatus',formatter: '.statusIcon'}" color="{path: 'CollaudoProgressModel>sfcStatus', formatter: '.statusColor'}" class="largeIcon" />
										</table:template>
									</table:Column>

								</table:columns>
							</table:Table>
						</VBox>
					</content>
				</Panel>
			</content>
		</Page>
</mvc:View>