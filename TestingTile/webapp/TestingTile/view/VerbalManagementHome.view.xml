<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form" xmlns:core="sap.ui.core" xmlns:html="http://www.w3.org/1999/xhtml" xmlns:table="sap.ui.table" controllerName="kpmg.custom.testingTile.TestingTile.TestingTile.controller.VerbalManagementHome" width="100%" height="100%">
		<Page id="mainVerbalManagementPage" title="{i18n>verbalManagement.title}">
			<content>
				<!-- Header con filtri -->
				<Panel id="filterVerbalMangementHomePanel" width="100%" height="100%" expandable="false" expanded="true" backgroundDesign="Transparent">
					<content>
						<VBox height="10%" renderType="Bare" class="sapUiSmallMargin">
							<!-- Filtri e Bottoni sulla stessa riga -->
							<HBox alignItems="End" justifyContent="SpaceBetween" width="100%">
								<!-- Filtri -->
								<VBox width="16%" height="100%" class="sapUiSmallMarginEnd">
									<Label text="{i18n>verbalManagement.filter.project}" />
									<ComboBox id="projectVerbalManagementFilter" width="100%" placeholder="{i18n>verbalManagement.filter.project.placeholder}" items="{verbalManagementModel>/projects}">
										<core:ListItem key="{verbalManagementModel>}" text="{verbalManagementModel>}" />
									</ComboBox>
								</VBox>
								
								<VBox width="16%" height="100%" class="sapUiSmallMarginEnd">
									<Label text="{i18n>verbalManagement.filter.co}"/>
									<ComboBox id="coVerbalManagementFilter" width="100%" placeholder="{i18n>verbalManagement.filter.co.placeholder}" items="{verbalManagementModel>/cos}" >
										<core:ListItem key="{verbalManagementModel>}" text="{verbalManagementModel>}" />
									</ComboBox>
								</VBox>

                                <VBox width="16%" height="100%" class="sapUiSmallMarginEnd">
									<Label text="{i18n>verbalManagement.filter.order}"/>
									<ComboBox id="orderVerbalManagementFilter" width="100%" placeholder="{i18n>verbalManagement.filter.order.placeholder}" items="{verbalManagementModel>/orders}" >
										<core:ListItem key="{verbalManagementModel>}" text="{verbalManagementModel>}" />
									</ComboBox>
								</VBox>

                                <VBox width="16%" height="100%" class="sapUiSmallMarginEnd">
									<Label text="{i18n>verbalManagement.filter.customer}"/>
									<ComboBox id="customerVerbalManagementFilter" width="100%" placeholder="{i18n>verbalManagement.filter.customer.placeholder}" items="{verbalManagementModel>/customers}" >
										<core:ListItem key="{verbalManagementModel>}" text="{verbalManagementModel>}" />
									</ComboBox>
								</VBox>
								
								
								<!-- Bottoni allineati verticalmente -->
								<VBox width="16%">
									<HBox width="100%" justifyContent="Center" class="sapUiTinyMarginBottom">
										<Button id="searchVerbalManagementButton" text="{i18n>mainview.btn.search}" icon="sap-icon://search" press="onSearchPress" type="Emphasized" class="sapUiTinyMarginEnd searchBottom"/>
										<Button id="clearVerbalManagementButton" text="{i18n>mainview.btn.clear}" icon="sap-icon://clear-filter" press="onClearPress" class="clearBottom" />
									</HBox>
                                        <HBox justifyContent="Center">
                                            <CheckBox id="showAllVerbalManagement" text="Show all" />
                                        </HBox>
								</VBox>
							</HBox>
						</VBox>
						<!-- Table -->
						<VBox height="85.5%" renderType="Bare">
							<table:Table
								id="verbalManagementTable"
								width="100%"
								busy="{verbalManagementModel>/BusyLoadingOpTable}" 
								rows="{verbalManagementModel>/tableData}"
								selectionMode="Single"
								ariaLabelledBy="title"
								rowSelectionChange="onRowSelectionChange"
								enableColumnReordering="true" 
								enableGrouping="true" 
								selectionBehavior="RowOnly"
								visibleRowCountMode="Auto"
								visibleRowCount="10" 
								rowHeight="45px"
								class="kpmgGDTable smallPaddingTable">
								<table:layoutData>
									<FlexItemData growFactor="1" baseSize="0%"/>
								</table:layoutData>
								<table:columns>
									<table:Column width="16%">
										<Label text="{i18n>verbalManagement.table.project}"/>
										<table:template>
											<Text text="{verbalManagementModel>project}" wrapping="false"/>
										</table:template>
									</table:Column>
									
									<table:Column width="16%">
										<Label text="{i18n>verbalManagement.table.sfc}"/>
										<table:template>
											<Text text="{verbalManagementModel>sfc}" wrapping="false"/>
										</table:template>
									</table:Column>
									
									<table:Column width="16%">
										<Label text="{i18n>verbalManagement.table.order}"/>
										<table:template>
											<Text text="{verbalManagementModel>order}" wrapping="false"/>
										</table:template>
									</table:Column>
									
									<table:Column width="16%">
										<Label text="{i18n>verbalManagement.table.co}"/>
										<table:template>
											<Text text="{verbalManagementModel>co}" wrapping="false"/>
										</table:template>
									</table:Column>
									
									<table:Column width="16%">
										<Label text="{i18n>verbalManagement.table.customer}"/>
										<table:template>
											<Text text="{verbalManagementModel>customer}" wrapping="false"/>
										</table:template>
									</table:Column>
									
									<table:Column width="16%">
										<Label text="{i18n>verbalManagement.table.status}"/>
										<table:template>
											<HBox width="100%" alignItems="Center" >
												<core:Icon src="{path: 'verbalManagementModel>status',formatter: '.statusIcon'}" color="{path: 'verbalManagementModel>status', formatter: '.statusColor'}" class="largeIcon" />
												<Text text="{verbalManagementModel>status}" class="smallMarginLeftTextIcon" />
											</HBox>
										</table:template>
									</table:Column>
								</table:columns>
							</table:Table>
						</VBox>
					</content>
				</Panel>
			</content>
		</Page>
</mvc:View>